# Relay Scheduler image (DESIGN.md §5.2) — the core control plane, gRPC server.
FROM python:3.12-slim
WORKDIR /app
COPY pyproject.toml ./
RUN pip install --no-cache-dir ".[scheduler]" || pip install --no-cache-dir \
    grpcio grpcio-tools redis asyncpg prometheus-client numpy structlog
COPY relay_core ./relay_core
COPY services ./services
COPY proto ./proto
ENV PYTHONPATH=/app RELAY_GRPC_PORT=50051
EXPOSE 50051 9101
CMD ["python", "-m", "services.scheduler.server"]
