# Relay environment (copy to .env). Values here match deploy/compose defaults.

# --- coordination / durable stores (DESIGN.md §5.4) ---
REDIS_URL=redis://localhost:6379/0
PG_DSN=postgresql://relay:relay@localhost:5432/relay

# --- gateway ---
PORT=8080
RELAY_QUEUE_HIGH_WATERMARK=10000      # admission shed threshold (queued items)

# --- scheduler (the core) ---
SCHEDULER_ADDR=localhost:50051
RELAY_GRPC_PORT=50051
RELAY_METRICS_PORT=9101
RELAY_ROUTING_POLICY=bounded          # bounded | affinity | round_robin
RELAY_LOAD_CAP_FACTOR=1.5             # the Pareto knob (DESIGN.md §8.2)

# --- worker (data plane) ---
RELAY_ENGINE=mock                     # mock | cache-aware-mock | ollama | torch-mps | vllm
RELAY_WORKER_MODELS=qwen2.5:0.5b
MAX_BATCH=16
MAX_CONCURRENT_BATCHES=4
OLLAMA_URL=http://localhost:11434     # only used when RELAY_ENGINE=ollama

# --- dev api key (matches deploy/postgres/init.sql seed) ---
# Authorization: Bearer dev-key-please-change
